96c7d1c2d2"],"title":"سایت","clickable":true,"product_bread_crumb":true,"is_landing":false,"show_in_site":true,"code":"main","enableTapsell":"true","pageParams":[null]},"dataUpdateCount":1,"dataUpdatedAt":1782595397738,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchMeta":null,"isFetching":false,"isInvalidated":false,"isPaused":false,"status":"success"},"queryKey":["content",{"query":{"getNavBar":true}}],"queryHash":"[\"content\",{\"query\":{\"getNavBar\":true}}]"},{"state":{"data":[{"url":"/image/banner_TopGifDesktop_0e4H1u_646140a6-0800-456c-bd4a-d3311c5fa3e5.gif","link":"https://www.technolife.com/landings/goldenInvestment","query":"{}","alt":null}],"dataUpdateCount":1,"dataUpdatedAt":1782595397671,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchMeta":null,"isFetching":false,"isInvalidated":false,"isPaused":false,"status":"success"},"queryKey":["content",{"query":{"__name":"get_top_gif","__variables":{"is_mobile":"Boolean","is_pdp":"Boolean","is_landing":"Boolean"},"get_top_gif":{"__args":{"is_mobile":"$is_mobile","is_pdp":"$is_pdp","is_landing":"$is_landing"},"url":true,"link":true,"query":true,"alt":true}}}],"queryHash":"[\"content\",{\"query\":{\"__name\":\"get_top_gif\",\"__variables\":{\"is_landing\":\"Boolean\",\"is_mobile\":\"Boolean\",\"is_pdp\":\"Boolean\"},\"get_top_gif\":{\"__args\":{\"is_landing\":\"$is_landing\",\"is_mobile\":\"$is_mobile\",\"is_pdp\":\"$is_pdp\"},\"alt\":true,\"link\":true,\"query\":true,\"url\":true}}}]"},{"state":{"data":{"page_filters":[{"title":"فیلتر براساس قیمت","price_range":{"min":0,"max":52000000},"items":null},{"title":"دسته بندی ها","price_range":null,"items":[{"name":"ساندبار","code":"11","enName":null},{"name":"اسپیکر بلوتوثی","code":"17","enName":null},{"name":"پارتی باکس","code":"315","enName":null},{"name":"باند خانگی","code":"566","enName":null},{"name":"اسپیکر و بلندگو","code":"1137","enName":null},{"name":"اسپیکر دسکتاپ","code":"1138","enName":null},{"name":"اسپیکر سقفی","code":"1387","enName":null}]},{"title":"رنگ ها","price_range":null,"items":[{"name":"خاکستری","code":"#8f8f8f","enName":null},{"name":"سفید","code":"#ffffff","enName":null},{"name":"طوسی","code":"#c4c7ce","enName":null},{"name":"مشکی","code":"#1a1a1a","enName":null}]}],"show_compare":false,"landing_carousel":null,"landing_carousel_title":null,"content":{"meta_title":"اسپیکر هارمن کاردن، خرید و قیمت اسپیکر harman kardon - تکنولایف","page_title":null,"meta_keywords":"هارمن کاردن, اسپیکر و بلندگو","meta_description":"خرید آنلاین انواع اسپیکر هارمن کاردن به همراه لیست قیمت، مشخصات فنی، بررسی تخصصی و مقایسه انواع speaker harman kardon با ضمانت اصالت کالا و گارانتی معتبر","description":"\u003ch1 class=\"title gold\"\u003eاسپیکر هارمن کاردن\u003c/h1\u003e\n\n\u003cp\u003eاین روزها بسیاری از ما دلمان می\u0026zwnj;خواهد تا در خانه، محل کار یا محل ورزش خود، اسپیکری عالی با کیفیت صدای مناسب داشته باشیم که به گوشی موبایلمان متصل شود. به این ترتیب می\u0026zwnj;توانیم بدون دغدغه از بابت USB یا کابل AUX از شنیدن صدای موسقی لذت ببریم. از طرف دیگر قابلیت حمل این اسپیکرها نیز اهمیت بسیاری دارد. از همین رو شاهد محصولات متعدد اسپیکرهای قابل حمل بلوتوثی در بازار هستیم. در این میان، اسپیکرهایی همانند هارمن کاردن، بهترین برند تولیدکننده به حساب می\u0026zwnj;آیند. در این بخش قصد داریم هارمن کاردن را به\u0026zwnj;صورت کامل به شما معرفی کنیم. \u003ca href=\"https://www.technolife.com/category/multimedia/speaker\"\u003eقیمت اسپیکر\u003c/a\u003e را به همراه آفرهای ویژه روزانه در سایت تکنولایف دنبال کنید.\u003c/p\u003e\n\n\u003ch2 class=\"title gold\"\u003eآشنایی با برند هارمن کاردن\u003c/h2\u003e\n\n\u003cp\u003eاگر قصد خرید اسپیکر هارمن کاردن را داشته باشید، باید ابتدا درباره برند هارمن کاردن اطلاعات بیشتری به دست بیاورید. در حال حاضر انواع اسپیکر harman Kardon در بازار وجود دارند؛ اما پیش از آنکه بخواهید درباره انواع مختلف اسپیکر harmon Kardon صحبت کنیم، باید درباره خود برند کمی حرف بزنیم. پیش از هر چیز باید بدانید که برند هارمن کاردن از جمله برندهای آمریکایی به حساب می\u0026zwnj;آید. جالب است بدانید که این برند جزو قدیمی\u0026zwnj;ترین برندهای تولیدکننده تجهیزات صوتی خودرو به حساب می\u0026zwnj;آید. شرکت اصلی یا همان شرکت مادر هولدینگ هارمن کاردن در سال 1953 میلادی افتتاح شد. در آن دوران این برند به دست سیدنی هارمن و برنارد کاردن افتتاح شد. به همین خاطر نام آن را هارمن کاردن گذاشتند. این برند در ابتدا تابلوهای آدرس خیابان\u0026zwnj;های عمومی را تولید می\u0026zwnj;کرد. در اواخر دهه 50 میلادی بود که این دو شریک، به فکر ساخت تجهیزات صوتی خودرو افتادند. در آن دوران خودروها تازه به بازار عرضه شده بودند. به همین خاطر کمتر کسی به\u0026zwnj;دنبال ساخت تجهیزات جانبی برای آن بود. در اواخر دهه 30 میلادی بود که نسخه\u0026zwnj;ای ساده از رادیو مخصوص خودرو ساخته شد؛ اما هارمن کاردن تصمیم گرفت تا وسیله\u0026zwnj;ای از ترکیب آمپلی\u0026zwnj;فایر، تیونر و پری آمپلی\u0026zwnj;فایر بسازد و در خودرو قرار دهد. در حقیقت از همان دوران بود که هارمن کاردن به دنیای موسیقی عرضه شد. به\u0026zwnj;تدریج محصولات مختلفی از هارمن کاردن در بازار به چشم می\u0026zwnj;خورد. هارمن کاردن در طول تاریخ می\u0026zwnj;توان گفت که همیشه در لیست پیش\u0026zwnj;گامان بود. برای مثال اولین ضبط صوت\u0026zwnj;های کاستی با کیفیت دالبی و سیستم حذف نویز، به دست هارمن کاردن تولید شد. این برند در سال 1969 توانست برند اصلی خود، یعنی JBL را خریداری کند. با پشتیبانی ریاست جمهوری آمریکا، یعنی جیمی کارتر، این برند قدرت بیشتری پیدا کرد. به همین ترتیب، سیستم\u0026zwnj;های صوتی مختلف CD را نیز همین برند به بازار عرضه کرد. در حقیقت این برند را می\u0026zwnj;توان برترین برند تولیدکننده تجهیزات صوتی در تمام دنیا دانست.\u003c/p\u003e\n\n\u003ch2 class=\"title gold\"\u003eمحصولات هارمن کاردن\u003c/h2\u003e\n\n\u003cp\u003eمحصولات هارمن کاردن در حال حاضر بسیار گسترده هستند. اگر سری به صفحه محصولات هارمن کاردن بزنید، متوجه می\u0026zwnj;شوید که علاوه\u0026zwnj;بر انواع اسپیکر هارمن کاردن ، انواع بلندگو خودرو، ضبط خودرو، آمپلی\u0026zwnj;فایر، میکسر، اسپیکر کامپیوتر، اسپیکرهای هوشمند، اسپیکر لپ\u0026zwnj;تاپ و ... توسط هارمن کاردن تولید می\u0026zwnj;شود. بد نیست بدانید که شرکت\u0026zwnj;های خودروها سازی اعم از سوبارو، نیسان، میتسوبیشی، جگوار، تویوتا، دوژ، آلفا، کرایسلر، مینی، هیوندا، کیا، بیوک، ولوو، رنج رور، مرسدس بنز، بی ام دبلیو، آئودی، فولکس واگن، لندرروو و چندین برند خودروسازی محبوب و قدرتمند دنیا، با هارمن کاردن همکاری می\u0026zwnj;کنند.\u003c/p\u003e\n\n\u003ch2 class=\"title gold\"\u003eاسپیکر هارمن کاردن\u003c/h2\u003e\n\n\u003cp\u003eاگر قصد خرید اسپیکر harman Kardon را دارید، باید خیالتان از بابت خرید خود راحت باشد. در تمامی انواع بررسی اسپیکر harman Kardon ، اسپیکرهای این برند در لیست بهترین برندهای دنیا قرار می\u0026zwnj;گیرد. وقتی که صحبت از برند هارمن کاردن به میان بیاید، همگی یاد محصولات بسیار باکیفیت و عالی می\u0026zwnj;افتند. اسپیکر هارمن کاردن به\u0026zwnj;معنای واقعی کلمه، یک اسپیکر قدرتمند با تفکیک صدای عالی، دوام فوق\u0026zwnj;العاده، طراحی زیبا و .کیفیت بی\u0026zwnj;نظیر است. هرچه درباره کیفیت انواع اسپیکر هارمن کاردن گفته شود، اصل کیفیت و دوام آن را به جای نمی\u0026zwnj;آورد. در حقیقت هارمن کاردن را در بازار صنایع صوتی می\u0026zwnj;توان مشابه اپل در تولید گوشی دانست. این برند حدود 70 سال در زمینه تولید اسپیکر سابقه دارد و هیچگاه محصولات بی\u0026zwnj;کیفیت تولید نمی\u0026zwnj;کند.\u003c/p\u003e\n\n\u003ch2 class=\"title gold\"\u003eقیمت اسپیکر harman Kardon\u003c/h2\u003e\n\n\u003cp\u003eهمیشه کیفیت و قیمت با هم رفاقت بسیاری دارند. وقتی که کیفیت بالا برود، قیمت شاهد افزایش قیمت هم خواهیم بود. پس اصلاً نمی\u0026zwnj;توان انتظار داشت که یک محصول باکیفیت را با قیمت ارزان تهیه کنیم. به این ترتیب همان طور که انتظار داریم، آنقدر که از کیفیت انواع اسپیکر هارمن کاردن صحبت کردیم، باید انتظار گرانی قیمت اسپیکر harman Kardon را نیز داشته باشیم. در حقیقت می\u0026zwnj;توان گفت که اسپیکر harman Kardon از جمله گران\u0026zwnj;ترین انواع اسپیکر در بازار به حساب می\u0026zwnj;آید. برای مثال قیمت یکی از محبوب\u0026zwnj;ترین مدل\u0026zwnj;های هارمن کاردن همانند اسپیکر هارمن کاردن go play ، بسیار گران است و می\u0026zwnj;توان گفت که شاید تا دو برابر قیمت محصولات دیگر باشد. البته قیمت این اسپیکرها وابستگی کامل به قیمت دلار دارد. با کاهش یا افزایش نرخ دلار، قیمت این اسپیکرها نیز تغییر پیدا می\u0026zwnj;کنند. البته درباره این اسپیکرها باید گفت که قیمت اسپیکر هارمن کاردن در مقایسه با کیفیتی که ارائه می\u0026zwnj;دهد، منطقی به نظر می\u0026zwnj;رسد. از طرف دیگر، همیشه این اسپیکرها بورس بازار هستند. به این ترتیب هر زمان که بخواهید آن\u0026zwnj;ها را بفروشید و یک مدل جدید بخرید، همیشه می\u0026zwnj;توانید بر اساس قیمت روز بازار، آن\u0026zwnj;ها را بفروشید و یک مدل جدیدتر تهیه کنید. پس با تمامی این اوصاف نمی\u0026zwnj;توان گفت که قیمت این اسپیکرها به\u0026zwnj;صورت نا عادلانه و غیرمنطقی گران است.\u003c/p\u003e\n\n\u003ch2 class=\"title gold\"\u003eطراحی اسپیکرهای هارمن کاردن\u003c/h2\u003e\n\n\u003cp\u003eجالب است بدانید که فقط کیفیت ساخت این اسپیکرها نیست که مناسب است. بلکه از نظر طراحی نیز اسپیکرهای هارمن کاردن بسیار زیبا و خاص هستند. برخی انواع این اسپیکرها طراحی بسیار منحصر\u0026zwnj;به\u0026zwnj;فردی دارند و مشابه آن را در بازار مشاهده نمی\u0026zwnj;کنید. همین موضوع باعث شده تا این اسپیکرها طرفداران مخصوص به خود را داشته باشند. در حقیقت هیچ برند دیگری قادر نیست تا چنین طراحی\u0026zwnj;های خاصی را ارائه دهد. برای مثال اسپیکر harman kardon aura studio 3 و اسپیکر harman kardon aura studio 4 یا اسپیکر harman kardon aura studio 2 دارای طراحی\u0026zwnj;های بسیار خاص و منحصر\u0026zwnj;به\u0026zwnj;فرد هستند. از طرف دیگر بر اساس گفته تولیدکنندگان اسپیکرهای هارمن کاردن، این طراحی فقط از نظر ظاهری نیست که زیبایی دارد. بلکه نوع طراحی باعث افزایش تفکیک و بلندی صدا نیز می\u0026zwnj;شود!\u003c/p\u003e\n\n\u003ch2 class=\"title gold\"\u003eمعرفی بهترین مدل های اسپیکر هارمن کاردن\u003c/h2\u003e\n\n\u003cp\u003eاگر قصد خرید اسپیکر هارمن کاردن را دارید، باید بتوانید بین چند مدل باید انتخاب کنید. به همین خاطر چند مدل از بهترین اسپیکرهای هارمن کاردن را به شما معرفی می\u0026zwnj;کنیم تا بتوانید بین آن\u0026zwnj;ها یکی را انتخاب نمایید.\u003c/p\u003e\n\n\u003cul\u003e\n\t\u003cli\u003e\n\t\u003ch3 class=\"title gold\"\u003eاسپیکر هارمن کاردن go play\u003c/h3\u003e\n\t\u003c/li\u003e\n\u003c/ul\u003e\n\n\u003cp\u003eاسپیکر هارمن کاردن go play یک اسپیکر بسیار قدرتمند است که می\u0026zwnj;توانید به\u0026zwnj;صورت سیمی یا بدون سیم استفاده کنید. این اسپیکر با امپدانس 10 اهم و نسبت سیگنال به نویز 80 دسی\u0026zwnj;بل می\u0026zwnj;تواند صدای بسیار مناسبی را برای کاربران ایجاد کند. لازم به ذکر است که اسپیکر هارمن کاردن go play از جمله محبوب\u0026zwnj;ترین و پرفروش\u0026zwnj;ترین محصولات هارمن کاردن به حساب می\u0026zwnj;آید. این محصول حدود 3 کیلو و نیم وزن دارد. به همین خاطر یک دسته بسیار محکم و مقاوم برای آن طراحی کرده\u0026zwnj;اند. به این ترتیب می\u0026zwnj;توانید به\u0026zwnj;راحتی و بدون مشکل، این اسپیکر را به مکان\u0026zwnj;های مختلف منتقل کنید. این اسپیکر ورودی\u0026zwnj;های محدودی دارد و امکان اتصال به وای فای در آن تعبیه نشده است. ب این حال عمر باتری بالا و همچنین کیفیت بیس عالی باعث شده تا اسپیکر هارمن کاردن go play به یکی از بهترین اسپیکرهای بازار تبدیل شود.\u003c/p\u003e\n\n\u003cul\u003e\n\t\u003cli\u003e\n\t\u003ch3 class=\"title gold\"\u003eاسپیکر harman kardon aura studio 3\u003c/h3\u003e\n\t\u003c/li\u003e\n\u003c/ul\u003e\n\n\u003cp\u003eاسپیکر harman kardon aura studio 3 دارای ظاهری بسیار زیباست. این اسپیکر را هرکه ببیند، عاشقش می\u0026zwnj;شود و می\u0026zwnj;خواهد یکی از آن را در خانه خود داشته باشد! از نظر ظاهری، اسپیکر harman kardon aura studio 3 شبیه به یک کپسول نیمه شیشه\u0026zwnj;ای است. در بخش داخلی این کپسول شیشه\u0026zwnj;ای، باند بیس اسپیکر harman kardon aura studio 3 قرار دارد. این فضای کپسولی هم زیبایی دارد و هم باعث افزایش میزان بیس می\u0026zwnj;شود. رقص نور اسپیکر harman kardon aura studio 3 بسیار زیباست. اسپیکر harman kardon aura studio 3 حدود 3 کیلو و نیم وزن دارد و امکان اتصال آن به آداپتور برق و پخش هم\u0026zwnj;زمان موسیقی در آن نیز تعبیه شده است. این دستگاه با کمک AUX به دستگاه\u0026zwnj;های مختلف نیز متصل می\u0026zwnj;شود. \u003ca href=\"https://www.technolife.com/product-3346/-%D8%A7%D8%B3%D9%BE%DB%8C%DA%A9%D8%B1-%D8%A8%D9%84%D9%88%D8%AA%D9%88%D8%AB%DB%8C-%D8%AE%D8%A7%D9%86%DA%AF%DB%8C-%D9%87%D8%A7%D8%B1%D9%85%D9%86-%DA%A9%D8%A7%D8%B1%D8%AF%D9%86-%D9%85%D8%AF%D9%84-aura-studio-3\"\u003eاسپیکر harman kardon aura studio 3\u003c/a\u003e صدای بسیار بلند و باکیفیتی دارد.\u003c/p\u003e\n\n\u003cul\u003e\n\t\u003cli\u003e\n\t\u003ch3 class=\"title gold\"\u003eاسپیکر harman kardon soundsticks 4\u003c/h3\u003e\n\t\u003c/li\u003e\n\u003c/ul\u003e\n\n\u003cp\u003e\u003ca href=\"https://www.technolife.com/product-3835/-%D8%A7%D8%B3%D9%BE%DB%8C%DA%A9%D8%B1-%D8%AF%D8%B3%DA%A9%D8%AA%D8%A7%D9%BE-%D9%87%D8%A7%D8%B1%D9%85%D9%86-%DA%A9%D8%A7%D8%B1%D8%AF%D9%86-%D9%85%D8%AF%D9%84-soundsticks-4\"\u003eاسپیکر harman kardon soundsticks 4\u003c/a\u003e که بسیاری آن را به اشتباه با نام اسپیکر هارمن کاردن aura studio 4 می\u0026zwnj;شناسند، از دیگر اسپیکرهای هارمن کاردن با طراحی بسیار خاص و منحصر\u0026zwnj;به\u0026zwnj;فرد است. از نظر ظاهری شباهت بسیاری بین اسپیکر هارمن کاردن aura studio 4 و اسپیکر harman kardon aura studio 3 وجود دارد. این اسپیکر همان کپسول زیبای شیشه\u0026zwnj;ای را دارد. در کنار این کپسول زیبای شیشه\u0026zwnj;ای دو باند خطی با چند اسپیکر کوچک داخل آن وجود دارد. این دو اسپیکر خطی باعث می\u0026zwnj;شوند تا صدای اسپیکر هارمن کاردن aura studio 4 وضوح و تفکیک بیشتری در مقایسه با مدل قبلی داشته باشد. البته همان طور که حدس می\u0026zwnj;زنید، قابلیت حمل این اسپیکر از مدل 3 کمتر است. به همین خاطر اکثر افرادی که قصد استفاده از اسپیکر به\u0026zwnj;صورت ثابت در خانه یا محل کار خود را دارند، اسپیکر هارمن کاردن aura studio 4 را انتخاب می\u0026zwnj;کنند.\u003c/p\u003e\n\n\u003ch2 class=\"title gold\"\u003eخرید اسپیکر هارمن کاردن از تکنولایف\u003c/h2\u003e\n\n\u003cp\u003eاسپیکرهای هارمن کاردن جزو انواع اسپیکرهای بسیار خاص و منحصر\u0026zwnj;به\u0026zwnj;فرد هستند. از طرف دیگر به\u0026zwnj;خاطر قیمت گران این محصولات، متأسفانه برخی افراد سودجو، مدل\u0026zwnj;های تقلبی آن را نیز به بازار عرضه می\u0026zwnj;کنند. به همین خاطر باید این محصولات را از فروشگاه\u0026zwnj;های معتبر در ایران تهیه کنید. تکنولایف از جمله معروف\u0026zwnj;ترین فروشگاه\u0026zwnj;های اینترنتی در زمینه محصولات دیجیتال محسوب می\u0026zwnj;شود. با توجه به اعتبار تکنولایف، بسیاری از مشتریان آن ترجیح می\u0026zwnj;دهند تا تمام محصولات دیجیتال خود را از تکنولایف تهیه کنند. خوشبختانه امکان خرید اسپیکرهای هارمن کاردن از تکنولایف نیز وجود دارد. به این ترتیب می\u0026zwnj;توانید اسپیکرهای اصل هارمن کاردن را با اطمینان از بابت کیفیت و قیمت به\u0026zwnj;راحتی از تکنولایف تهیه کرده و درب منزل تحویل بگیرید.\u003c/p\u003e\n","name":"اسپیکر و بلندگو هارمن کاردن","image":null,"canonical":"/category/multimedia/speaker/brand-harman-kardon","base_url":"/category/multimedia/speaker/brand-harman-kardon","no_index":false}},"dataUpdateCount":1,"dataUpdatedAt":1782595397757,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchMeta":null,"isFetching":false,"isInvalidated":false,"isPaused":false,"status":"success"},"queryKey":["content",{"query":{"__name":"get_menu_filters","__variables":{"url":"String","filterObj":"filter_obj"},"get_menu_filters":{"__args":{"url":"$url","filterObj":"$filterObj"},"page_filters":{"title":true,"price_range":{"min":true,"max":true},"items":{"name":true,"code":true,"enName":true}},"show_compare":true,"landing_carousel":{"image":true,"url":true,"name":true},"landing_carousel_title":true,"content":{"meta_title":true,"page_title":true,"meta_keywords":true,"meta_description":true,"description":true,"name":true,"image":true,"canonical":true,"base_url":true,"no_index":true}}}},{"url":"category/multimedia/speaker/brand-harman-kardon","filterObj":{"page_type":"dynamic","limit":30}}],"queryHash":"[\"content\",{\"query\":{\"__name\":\"get_menu_filters\",\"__variables\":{\"filterObj\":\"filter_obj\",\"url\":\"String\"},\"get_menu_filters\":{\"__args\":{\"filterObj\":\"$filterObj\",\"url\":\"$url\"},\"content\":{\"base_url\":true,\"canonical\":true,\"description\":true,\"image\":true,\"meta_description\":true,\"meta_keywords\":true,\"meta_title\":true,\"name\":true,\"no_index\":true,\"page_title\":true},\"landing_carousel\":{\"image\":true,\"name\":true,\"url\":true},\"landing_carousel_title\":true,\"page_filters\":{\"items\":{\"code\":true,\"enName\":true,\"name\":true},\"price_range\":{\"max\":true,\"min\":true},\"title\":true},\"show_compare\":true}}},{\"filterObj\":{\"limit\":30,\"page_type\":\"dynamic\"},\"url\":\"category/multimedia/speaker/brand-harman-kardon\"}]"},{"state":{"data":[{"position":0,"name":"تکنولایف","url":"/"},{"position":1,"name":"صوتی تصویری","url":"/category/multimedia"},{"position":2,"name":"اسپیکر و بلندگو","url":"/category/multimedia/speaker"},{"position":3,"name":"اسپیکر و بلندگو هارمن کاردن","url":"/category/multimedia/speaker/brand-harman-kardon"}],"dataUpdateCount":1,"dataUpdatedAt":1782595397670,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchMeta":null,"isFetching":false,"isInvalidated":false,"isPaused":false,"status":"success"},"queryKey":["content",{"query":{"__name":"getBreadCrumbProductList","__variables":{"url":"String!"},"getBreadCrumbProductList":{"__args":{"url":"$url"},"position":true,"name":true,"url":true}}},{"url":"/category/multimedia/speaker/brand-harman-kardon"}],"queryHash":"[\"content\",{\"query\":{\"__name\":\"getBreadCrumbProductList\",\"__variables\":{\"url\":\"String!\"},\"getBreadCrumbProductList\":{\"__args\":{\"url\":\"$url\"},\"name\":true,\"position\":true,\"url\":true}}},{\"url\":\"/category/multimedia/speaker/brand-harman-kardon\"}]"},{"state":{"data":[],"dataUpdateCount":1,"dataUpdatedAt":1782595397669,"error":null,"errorUpdateCount":0,"errorUpdatedAt":0,"fetchFailureCount":0,"fetchMeta":null,"isFetching":false,"isInvalidated":false,"isPaused":false,"status":"success"},"queryKey":["content",{"query":{"__name":"getSubBreadCrumbProductList","__variables":{"url":"String!"},"getSubBreadCrumbProductList":{"__args":{"url":"$url"},"position":true,"name":true,"url":true,"image":true}}},{"url":"/category/multimedia/speaker/brand-harman-kardon"}],"queryHash":"[\"content\",{\"query\":{\"__name\":\"getSubBreadCrumbProductList\",\"__variables\":{\"url\":\"String!\"},\"getSubBreadCrumbProductList\":{\"__args\":{\"url\":\"$url\