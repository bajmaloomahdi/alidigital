        <button class="slider-prev" style="position:absolute;top:50%;left:0;transform:translateY(-50%);background:#0073aa;color:#fff;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">&#10095;</button>
        <button class="slider-next" style="position:absolute;top:50%;right:0;transform:translateY(-50%);background:#0073aa;color:#fff;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">&#10094;</button>
    </div>

<script>
(function(){
    const track = document.querySelector('.abzarline-slider-track');
    const prev = document.querySelector('.slider-prev');
    const next = document.querySelector('.slider-next');
    const containerWidth = track.parentElement.offsetWidth;
    const cardWidth = track.querySelector('.product-card').offsetWidth + 10; // margin-right

    let position = 0;
    const maxScroll = track.scrollWidth - containerWidth;
    track.style.display = 'flex';
    track.style.flexDirection = 'row-reverse';
    track.style.transition = 'transform 0.3s ease';
    track.style.transform = `translateX(0px)`;

    next.addEventListener('click', () => {
        position += cardWidth;
        if(position > maxScroll) position = maxScroll;
        track.style.transform = `translateX(-${position}px)`;
    });

    prev.addEventListener('click', () => {
        position -= cardWidth;
        if(position < 0) position = 0;
        track.style.transform = `translateX(-${position}px)`;
    });
})();
</script>
    </div>
