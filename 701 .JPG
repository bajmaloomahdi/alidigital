<style id="wd-style-base-inline-css">
@font-face {
	font-weight: normal;
	font-style: normal;
	font-family: "woodmart-font";
	src: url("//nashremaaref.ir/wp-content/themes/woodmart/fonts/woodmart-font-3-400.woff2?v=8.5.2") format("woff2");
}

@font-face {
	font-family: "star";
	font-weight: 400;
	font-style: normal;
	src: url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/star.eot?#iefix") format("embedded-opentype"), url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/star.woff") format("woff"), url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/star.ttf") format("truetype"), url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/star.svg#star") format("svg");
}

@font-face {
	font-family: "WooCommerce";
	font-weight: 400;
	font-style: normal;
	src: url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/WooCommerce.eot?#iefix") format("embedded-opentype"), url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/WooCommerce.woff") format("woff"), url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/WooCommerce.ttf") format("truetype"), url("//nashremaaref.ir/wp-content/plugins/woocommerce/assets/fonts/WooCommerce.svg#WooCommerce") format("svg");
}


